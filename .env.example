# ============================================================
# CRM ГѓЖ’Г‚ВўГѓВўГўв‚¬ЕЎГ‚В¬ГѓВўГўвЂљВ¬Г‚Вќ Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# ======================
# Database
# ======================
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/crm_db
POSTGRES_PASSWORD=

# Production DB Tunnel (optional ГѓЖ’Г‚ВўГѓВўГўв‚¬ЕЎГ‚В¬ГѓВўГўвЂљВ¬Г‚Вќ for accessing remote DB via SSH)
ENABLE_PROD_DB_TUNNEL=false
PROD_DB_SSH_TARGET=
PROD_DB_SSH_PORT=22
# Pake 5431 di VPS biar gak bentrok sama PostgreSQL lain
PROD_DB_LOCAL_PORT=5431
PROD_DB_REMOTE_HOST=127.0.0.1
PROD_DB_REMOTE_PORT=5432
PROD_DB_TUNNELED_DATABASE_URL=

# ======================
# Session & Auth
# ======================
SESSION_SECRET=
JWT_SECRET=
BETTER_AUTH_SECRET=development-secret-change-in-production
BETTER_AUTH_BASE_URL=http://localhost:3010/auth

# ======================
# Server
# ======================
PORT=3010
NODE_ENV=development
VITE_API_URL=http://localhost:3010
VITE_SOCKET_URL=http://localhost:3010

# ======================
# Socket.IO
# ======================
SOCKET_IO_PATH=/socket.io
SOCKET_IO_CORS_ORIGIN=http://localhost:3005,http://localhost:5173

# ======================
# Redis
# ======================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ======================
# Meta WhatsApp
# ======================
META_VERIFY_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WABA_ID=
WHATSAPP_REDIRECT_URI=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
BAILEYS_PROVIDER_WEBHOOK_URL=
BAILEYS_PROVIDER_WEBHOOK_PATH=
BAILEYS_SERVICE_URL=http://127.0.0.1:3012
WHATSAPP_SERVICE_PORT=3012
BAILEYS_SERVICE_INTERNAL_TOKEN=
WABA_CONFIG_ID=

# ======================
# Meta Instagram
# ======================
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_ACCESS_TOKEN=
IG_REDIRECT_URI=

# ======================
# Facebook App
# ======================
FB_APP_ID=
FB_APP_SECRET=

# ======================
# Frontend URL(s)
# ======================
FRONTEND_URL=http://localhost:3005,http://localhost:3006

# ======================
# AI Configuration
# ======================
AI_ENABLED=false
AI_PROVIDER=azure
AI_MODEL=gpt-4-turbo
OPENAI_API_KEY=

# Task list AI analyzer (2-tier OpenAI). Optional OPENAI_BASE_URL for proxy/Azure-compatible gateway.
OPENAI_BASE_URL=
OPENAI_CLASSIFIER_MODEL=gpt-4.1-nano
OPENAI_GENERATOR_MODEL=gpt-4.1-mini

# Deepgram speech-to-text (used by the WhatsApp number voice helper)
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3-general
DEEPGRAM_KEYWORDS=
CHUNK_DURATION_SEC=1800
DIRECT_THRESHOLD_SEC=3600
# Optional override. Windows development uses the bundled FFmpeg binary by default.
FFMPEG_PATH=

# Optional transcript polish / summarization provider
TRANSCRIPT_POLISH=0
GLM_API_KEY=
GLM_BASE_URL=https://api.z.ai/api/paas/v4
GLM_MODEL=glm-5.2

# Personal WhatsApp AI reply (Ollama + LangChain)
OLLAMA_BASE_URL=https://ollama.contrivent.com
OLLAMA_CHAT_MODEL=qwen3.5:4b
OLLAMA_EMBED_MODEL=nomic-embed-text:latest
# Negative keeps the models warm in Ollama. //
OLLAMA_KEEP_ALIVE=-1
PERSONAL_AI_REVIEW_DELAY_SECONDS=4
PERSONAL_AI_REPLY_DELAY_SECONDS=15
# Maximum time for one Ollama review/compose request.
PERSONAL_AI_MODEL_TIMEOUT_MS=30000

# Azure OpenAI (if AI_PROVIDER=azure)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ======================
# Worker Configuration
# ======================
WORKER_CONCURRENCY=15
WORKER_CHANNELS=whatsapp
# Keep routine polling concise. Enable only while debugging a specific job/query.
PRISMA_LOG_QUERIES=false
WORKER_VERBOSE_LOGS=false
# Log WhatsApp history sync only at each N percent.
WHATSAPP_SYNC_PROGRESS_STEP=10

# ======================
# Cloudflare R2 Storage
# ======================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ======================
# Cloudflare Tunnel (optional)
# ======================
CLOUDFLARED_TUNNEL_TOKEN=
TUNNEL_API_HOST=local-api.crm.chat
TUNNEL_FE_HOST=local-fe.crm.chat

# ======================
# n8n Integration (optional)
# ======================
N8N_EMBED_COOKIE_DOMAIN=

# ======================
# TikTok (optional)
# ======================
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_APP_ID=
TIKTOK_CLIENT_ID=
TIKTOK_REDIRECT_URI=

# ======================
# CEO bootstrap (used once by `bun run db:seed:ceo`)
# ======================
SEED_CEO_EMAIL=
SEED_CEO_PASSWORD=

# Backend service
REDIS_URL=redis://localhost:6379
APP_MODE=api
SOCKET_PORT=3011
SOCKET_IO_TRANSPORTS=websocket
APP_URL=http://localhost:3010
WHATSAPP_WEBHOOK_CALLBACK_URL=
# Local MinIO defaults. Replace credentials outside local development.
MINIO_ROOT_USER=crm_minio
MINIO_ROOT_PASSWORD=crm_minio_change_me
S3_ENDPOINT=http://127.0.0.1:9000
S3_REGION=auto
S3_ACCESS_KEY=crm_minio
S3_SECRET_KEY=crm_minio_change_me
S3_BUCKET=crm-media
S3_PUBLIC_URL=http://127.0.0.1:9000
S3_PUBLIC_URL_STYLE=path
R2_ENDPOINT=
R2_REGION=auto

# WhatsApp service
CRM_BAILEYS_WEBHOOK_PATH=/api/personal-whatsapp-inbox/ingest
BAILEYS_LINK_MODE=qr
BAILEYS_CHANNEL_SYNC_INTERVAL_MS=15000
HOST=127.0.0.1
BAILEYS_DB_POOL_MAX=10
# Encrypts persisted Baileys credentials (required in production; use a long random secret)
BAILEYS_AUTH_ENCRYPTION_KEY=
