{
	"apps": [
		{
			"name": "crm-api",
			"cwd": "/var/www/crm/apps/backend",
			"script": "dist/index.js",
			"interpreter": "bun",
			"env": {
				"APP_MODE": "api",
				"NODE_ENV": "production"
			},
			"env_file": "/var/www/crm/.env.production"
		},
		{
			"name": "crm-worker",
			"cwd": "/var/www/crm/apps/backend",
			"script": "dist/index.js",
			"interpreter": "bun",
			"env": {
				"APP_MODE": "worker",
				"NODE_ENV": "production"
			},
			"env_file": "/var/www/crm/.env.production"
		},
		{
			"name": "crm-scheduler",
			"cwd": "/var/www/crm/apps/backend",
			"script": "dist/index.js",
			"interpreter": "bun",
			"env": {
				"APP_MODE": "scheduler",
				"NODE_ENV": "production"
			},
			"env_file": "/var/www/crm/.env.production"
		},
		{
			"name": "crm-frontend",
			"cwd": "/var/www/crm/apps/frontend",
			"script": ".output/server/index.mjs",
			"interpreter": "bun",
			"env": {
				"PORT": "3100",
				"NODE_ENV": "production"
			},
			"env_file": "/var/www/crm/.env.production"
		}
	]
}
