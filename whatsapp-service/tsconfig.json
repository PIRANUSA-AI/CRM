{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "NodeNext",
		"strict": true,
		"skipLibCheck": true,
		"allowSyntheticDefaultImports": true,
		"esModuleInterop": true,
		"types": ["node"],
		"noEmit": false,
		"outDir": "dist",
		"rootDir": "src",
		"declaration": false,
		"sourceMap": true
	},
	"include": ["src/**/*.ts"]
}
